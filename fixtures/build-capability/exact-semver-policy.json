{
  "scenario": "exact-semver-policy",
  "steps": [
    "studio capability init demo-policy --dir /tmp/demo-policy",
    "node -e \"const fs=require('fs');const p='/tmp/demo-policy/package.json';const j=JSON.parse(fs.readFileSync(p,'utf8'));j.dependencies.react='^18.3.1';fs.writeFileSync(p,JSON.stringify(j,null,2));\"",
    "studio capability validate /tmp/demo-policy --json"
  ],
  "expect": {
    "ok": false,
    "error_codes": ["DEVKIT_VERSION_NOT_EXACT"]
  }
}
