{
  "name": "agent-studio",
  "version": "1.0.0",
  "description": "Agent Review Studio — local-first human/agent review loop",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @murrmure/cli build && pnpm --parallel --filter @murrmure/hub-daemon --filter @murrmure/shell-web dev",
    "build": "pnpm -r build",
    "shell:build:bundled": "pnpm --filter @murrmure/shell-web build:bundled",
    "desktop:dev:smoke": "pnpm --filter @murrmure/shell-ui typecheck && pnpm --filter @murrmure/shell-web build:bundled && pnpm --filter @murrmure/hub-daemon build && pnpm --filter @murrmure/desktop dev",
    "desktop:dev:hmr": "pnpm --filter @murrmure/shell-ui typecheck && bun run apps/desktop/scripts/run-dev-hmr.ts",
    "desktop:dev:hmr:hub": "PORT=${PORT:-${HUB_PORT:-8787}} bun run apps/desktop/scripts/run-hmr-hub.ts",
    "desktop:dev:hmr:shell": "pnpm --filter @murrmure/shell-web dev:bundled",
    "desktop:dev:hmr:window": "pnpm --filter @murrmure/desktop dev:hmr",
    "desktop:build": "pnpm --filter @murrmure/shell-web build:bundled && pnpm --filter @murrmure/hub-daemon build && pnpm --filter @murrmure/desktop build:bundle",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "vitest run --project @murrmure/hub-daemon --project @murrmure/cli",
    "check:boundaries": "depcruise packages/runtime-kernel/src packages/runtime-contracts/src packages/runtime-persistence/src packages/runtime-adapter-http/src packages/contracts/src packages/hub-core/src packages/hub-persistence/src packages/hub-daemon/src packages/executors/src packages/shell-ui/src packages/shell-client/src packages/shell-web/src packages/view-sdk/src packages/cli/src --config dependency-cruiser.config.cjs",
    "spec:lint": "node scripts/spec-lint-cloudevents.mjs",
    "docs:dev": "pnpm --filter @murrmure/docs dev",
    "docs:build": "pnpm --filter @murrmure/docs build",
    "docs:preview": "pnpm --filter @murrmure/docs preview",
    "storybook": "pnpm --filter @murrmure/storybook dev",
    "storybook:build": "pnpm --filter @murrmure/storybook build",
    "storybook:snapshots": "pnpm --filter @murrmure/storybook snapshots",
    "murrmure-hub": "pnpm --filter @murrmure/hub-daemon dev",
    "check:doc-tracker": "node scripts/check-doc-tracker.mjs",
    "check:doc-tracker:strict": "node scripts/check-doc-tracker.mjs --strict",
    "check:known-gaps": "node scripts/check-known-gaps.mjs",
    "check:fdk-docs": "node scripts/check-fdk-docs.mjs",
    "check:clean-state": "node scripts/check-clean-state.mjs",
    "check:run-scratch-paths": "node scripts/check-run-scratch-paths.mjs",
    "check:nested-call-return": "node scripts/check-nested-call-return.mjs",
    "check:docs-proof": "pnpm --filter @murrmure/cli build && pnpm check:known-gaps && pnpm check:fdk-docs && pnpm check:clean-state && pnpm check:run-scratch-paths && pnpm check:nested-call-return && pnpm --filter @murrmure/cli test docs-proof",
    "examples:build": "pnpm --filter @murrmure/cli build && node test-utils/spaces/preview-review-v2/.mrmr/space/scripts/preview-review-build.mjs",
    "sources:fetch": "node scripts/fetch-sources.mjs",
    "sources:list": "OPENSRC_HOME=.opensrc pnpm exec opensrc list",
    "sources:path": "OPENSRC_HOME=.opensrc pnpm exec opensrc path",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gael-boyenval/murrmure.git"
  },
  "bugs": {
    "url": "https://github.com/gael-boyenval/murrmure/issues"
  },
  "homepage": "https://github.com/gael-boyenval/murrmure#readme",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.10.0",
    "opensrc": "^0.7.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
