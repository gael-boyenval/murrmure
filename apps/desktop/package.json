{
  "name": "@murrmure/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/dev-main.ts",
    "dev:hmr": "MURRMURE_DESKTOP_DEV_HMR=1 bun x electrobun dev",
    "dev:window": "bun run src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build:bundle": "bun x electrobun build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "electrobun": "^1.18.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/three": "^0.184.1"
  }
}
