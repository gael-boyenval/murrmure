{
  "$schema": "./removal-manifest.schema.json",
  "version": 1,
  "description": "Single source of truth for clean-slate removed vocabulary. Drives scripts/check-removal-matrix.mjs. Sources: Tasks 01–15, check-clean-state, Task 15 review findings.",
  "task_sources": {
    "00": "contracts + tutorial harness",
    "01": "clean boot, no seed/catalog/FDK",
    "02": "connection create/activate, no grant/agent/onboard",
    "03": "resolver-agnostic steps, no start/requires_view/role/presentation/wait",
    "04": "view_resolver, no built-in forms/view_ref/GateResolvePanel",
    "05": "branch artifact contracts",
    "06": "safe shell handler, no kill_on",
    "07": "agent prompt protocol",
    "08": "nested call/return, no complete_parent/goto",
    "09": "run capacity",
    "10": "cleanup commit",
    "11": "artifacts retention",
    "12": "shared flow page",
    "13": "clean-slate removal gate",
    "14": "release acceptance",
    "15": "legacy v2 runtime + docs"
  },
  "rule_path_suppressions": {
    "mcp-invoke-action": [
      "packages/cli/skill-agent/SKILL.md",
      "packages/cli/skill-agent/reference/mcp.md"
    ],
    "mcp-complete-action": [
      "packages/cli/skill-agent/SKILL.md",
      "packages/cli/skill-agent/reference/mcp.md"
    ],
    "mcp-wait-for-gate": [
      "packages/cli/skill-agent/SKILL.md",
      "packages/cli/skill-agent/reference/mcp.md"
    ],
    "mcp-resolve-gate": [
      "packages/cli/skill-agent/SKILL.md",
      "packages/cli/skill-agent/reference/mcp.md"
    ],
    "grant-mint-command": ["CHANGELOG.md", "packages/cli/CHANGELOG.md", "packages/hub-daemon/CHANGELOG.md"],
    "grant-use-command": ["CHANGELOG.md", "packages/cli/CHANGELOG.md"],
    "capability-action-invoke": [
      "studio-specs/current/bridges/grants-migration.md",
      "apps/docs/guide/tutorials/index.md"
    ],
    "hub-token-local-export": [
      "apps/docs/reference/environment.md",
      "apps/docs/guide/space-handlers.md",
      "apps/docs/guide/cli.md",
      "apps/docs/guide/troubleshooting.md",
      "apps/docs/guide/agents-mcp.md"
    ],
    "requires-view-field": [
      "packages/hub-core/src/index/parse-flow-manifest.ts",
      "packages/contracts/src/flow/manifest.ts",
      "packages/hub-core/src/flow-engine/engine-capabilities.ts"
    ],
    "derive-role-field": [
      "packages/hub-core/src/flow-engine/step-contract-compile.ts",
      "packages/contracts/src/entities/step-contract.ts"
    ],
    "flow-view-ref": [
      "packages/contracts/src/flow/ir.ts",
      "packages/hub-core/src/index/apply-index.ts",
      "packages/shell-client/src/types.ts"
    ],
    "checkpoint-resolve-command": [
      "packages/hub-core/src/handlers/hub.ts",
      "packages/runtime-kernel/src/checkpoint/lifecycle.ts",
      "packages/runtime-kernel/test/conformance/hardened-golden.test.ts",
      "packages/hub-core/test/integration/j01.test.ts"
    ],
    "legacy-studio-hub-mcp": [
      "packages/cli/src/lib/space-doctor-mcp.ts"
    ],
    "public-action-invoke-route": [
      "packages/hub-daemon/src/routes/federation/index.ts",
      "packages/hub-daemon/src/federation-wire.ts"
    ],
    "capability-gate-resolve": [
      "studio-specs/current/bridges/grants-migration.md",
      "apps/docs/guide/tutorials/index.md"
    ]
  },
  "path_allowlists": {
    "archive": [
      "studio-specs/current/clean-slate/**",
      "studio-specs/archives/**",
      "studio-specs/plans/**",
      "CHANGELOG.md",
      "packages/*/CHANGELOG.md",
      "apps/docs/CHANGELOG.md"
    ],
    "test_and_enforcement": [
      "**/test/**",
      "**/*.test.ts",
      "**/*.test.tsx",
      "scripts/check-clean-state.mjs",
      "scripts/check-removal-matrix.mjs",
      "scripts/check-run-scratch-paths.mjs",
      "scripts/check-nested-call-return.mjs",
      "packages/cli/test/docs-proof.test.ts"
    ],
    "fixtures": [
      "studio-specs/current/fixtures/**",
      "test-utils/**",
      "fixtures/**"
    ]
  },
  "surfaces": {
    "production": {
      "blocking": true,
      "roots": [
        "packages/contracts/src",
        "packages/hub-daemon/src",
        "packages/hub-core/src",
        "packages/cli/src",
        "packages/view-sdk/src",
        "packages/executors/src",
        "packages/mcp-bridge/src",
        "packages/runtime-contracts/src",
        "packages/runtime-kernel/src",
        "packages/runtime-adapter-http/src",
        "packages/runtime-persistence/src",
        "packages/shell-web/src",
        "packages/shell-client/src",
        "apps/desktop/src"
      ],
      "extra_files": ["apps/desktop/electrobun.config.ts"],
      "extensions": [".ts", ".tsx", ".js", ".mjs", ".json"]
    },
    "active_guidance": {
      "blocking": true,
      "roots": [
        "apps/docs",
        "studio-specs/current",
        "packages/cli/skill-agent",
        "packages/cli/skill-developer",
        "packages/cli/templates",
        "README.md",
        "studio-specs/README.md"
      ],
      "extensions": [".md", ".yaml", ".yml", ".json", ".ts"]
    },
    "scaffolds": {
      "blocking": true,
      "roots": ["packages/cli/templates"],
      "extensions": [".md", ".yaml", ".yml", ".json", ".ts", ".mjs"]
    },
    "flow_manifests": {
      "blocking": true,
      "roots": [
        "test-utils/spaces",
        "studio-specs/current/fixtures",
        "packages/cli/templates"
      ],
      "extensions": [".yaml", ".yml"],
      "files_glob": ["**/flow.manifest.yaml", "**/flow.manifest.yml"]
    },
    "shell_ui": {
      "blocking": true,
      "roots": ["packages/shell-web/src", "packages/shell-client/src"],
      "extensions": [".ts", ".tsx"]
    }
  },
