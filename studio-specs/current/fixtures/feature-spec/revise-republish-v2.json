{
  "description": "FS-full — revise_spec then republish emits version 2 (Amendment B dedup key)",
  "contract_fixture": "contracts/feature-spec-v1.json",
  "extends": "happy-path-publish.json",
  "steps": [
    {
      "actor": "human",
      "role": "space:admin",
      "tool": "transition_spec",
      "event": "revise_spec",
      "expect": { "state": "draft", "metadata_version": 2 }
    },
    {
      "actor": "human",
      "via": "shell",
      "action": "publish",
      "expect": { "state": "published" }
    },
    {
      "actor": "system",
      "action": "journal_tail",
      "expect": { "event_type": "spec.published", "payload.version": 2 }
    }
  ]
}
