{
  "description": "FS-min — agent drafts spec, human publishes (skip_review), spec.published fires",
  "contract_fixture": "contracts/feature-spec-v1.json",
  "contract_ref_id": "cref_feature_spec",
  "space_id": "spc_product_specs",
  "install_config": {
    "skip_review": true,
    "required_approver_role": "spec_approver"
  },
  "steps": [
    {
      "actor": "agent",
      "tool": "open_spec",
      "input": { "title": "Auth refresh token rotation" },
      "expect": { "state": "gathering_context", "spec_key_prefix": "ins_" }
    },
    {
      "actor": "agent",
      "tool": "patch_spec_section",
      "sections": [
        { "id": "goals", "title": "Goals", "body": "Rotate refresh tokens on use.", "order": 1 },
        { "id": "api", "title": "API", "body": "POST /auth/refresh returns new pair.", "order": 2 }
      ]
    },
    {
      "actor": "agent",
      "tool": "transition_spec",
      "event": "context_ready",
      "expect": { "state": "draft" }
    },
    {
      "actor": "human",
      "via": "shell",
      "action": "publish",
      "expect": { "state": "published" }
    },
    {
      "actor": "system",
      "action": "journal_tail",
      "expect": {
        "event_type": "spec.published",
        "payload.title": "Auth refresh token rotation",
        "payload.body_ref_prefix": "blob:",
        "payload.published_by_prefix": "act_"
      }
    }
  ]
}
