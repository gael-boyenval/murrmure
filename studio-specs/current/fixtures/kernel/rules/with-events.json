{
  "schema_version": "1.0",
  "id": "signal-only",
  "version": "1.0.0",
  "initial_state": "open",
  "terminal_states": ["closed"],
  "metadata_schema": { "type": "object" },
  "states": [
    { "id": "open", "kind": "active" },
    { "id": "closed", "kind": "terminal" }
  ],
  "transitions": [
    {
      "id": "t-close",
      "from": "open",
      "to": "closed",
      "event": "close",
      "actors": ["*"],
      "condition": null,
      "checkpoint": null,
      "emit": []
    }
  ],
  "events": {
    "declarations": [
      {
        "type": "external.signal",
        "schema": {
          "type": "object",
          "properties": { "source": { "type": "string" } },
          "required": ["source"],
          "additionalProperties": false
        }
      }
    ]
  }
}
