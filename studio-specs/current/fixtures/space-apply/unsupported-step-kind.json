{
  "description": "Phase 01 — wait step warns as unsupported engine dispatch",
  "bundle": {
    "actions": {
      "digest": "sha256:actions1",
      "file": {
        "version": 1,
        "actions": {
          "hello": { "executor": "shell" }
        }
      }
    },
    "executors": {
      "digest": "sha256:exec1",
      "file": {
        "executors": {
          "shell": { "binding": { "type": "shell_spawn", "executor_id": "shell" } }
        }
      }
    },
    "hooks": {
      "digest": "sha256:hooks1",
      "file": { "version": 1, "hooks": {} }
    },
    "flows": [
      {
        "flow_id": "flw_wait_only",
        "rel_path": "flows/wait-only/flow.manifest.yaml",
        "digest": "sha256:flow1",
        "manifest": {
          "apiVersion": "murrmure.flow/v1",
          "name": "wait-only",
          "start": { "manual": true },
          "steps": [{ "id": "hold" }]
        },
        "raw": {
          "apiVersion": "murrmure.flow/v1",
          "name": "wait-only",
          "start": { "manual": true },
          "steps": [{ "id": "hold" }]
        }
      }
    ],
    "views": []
  },
  "expect": {
    "warnings_contain": [
      { "code": "UNSUPPORTED_STEP_KIND", "step_id": "hold" },
      { "code": "DEPRECATED_START_KEY" }
    ],
    "strict_fails": true
  }
}
