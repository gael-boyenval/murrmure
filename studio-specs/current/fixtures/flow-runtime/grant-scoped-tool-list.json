{
  "description": "CR-min — grant ACL hides flow tools from worker token",
  "space_id": "spc_ui_sandbox",
  "installs": [
    { "flow_id": "review-loop", "version": "2.0.0", "state": "live" },
    { "flow_id": "feature-spec", "version": "1.1.0", "state": "live" }
  ],
  "tokens": [
    {
      "label": "worker-no-feature-spec",
      "scopes": ["space:read", "state:transition", "event:emit"],
      "flow_acl": ["review-loop"]
    },
    {
      "label": "builder-with-feature-spec",
      "scopes": ["space:read", "state:transition", "flow:install"],
      "flow_acl": ["review-loop", "feature-spec"]
    }
  ],
  "steps": [
    {
      "token": "worker-no-feature-spec",
      "action": "mcp_tools_list",
      "expect": {
        "tools_includes": ["transition", "create_review_session"],
        "tools_excludes": ["open_spec", "publish_spec", "add_context_ref"]
      }
    },
    {
      "token": "builder-with-feature-spec",
      "action": "mcp_tools_list",
      "expect": { "tools_includes": ["open_spec", "publish_spec", "add_context_ref"] }
    },
    {
      "token": "worker-no-feature-spec",
      "action": "mcp_tools_call",
      "tool": "publish_spec",
      "expect": { "error_code": "TOOL_NOT_AUTHORIZED" }
    }
  ]
}
