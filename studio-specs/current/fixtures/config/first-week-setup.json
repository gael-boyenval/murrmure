{
  "description": "Config CS-min — overview first-week checklist via HTTP",
  "journeys": ["company-01/overview-first-week"],
  "actors": {
    "admin": { "token_env": "STUDIO_BOOTSTRAP_TOKEN", "then": "STUDIO_ADMIN_TOKEN" },
    "worker_agent": { "token_env": "STUDIO_WORKER_TOKEN" }
  },
  "steps": [
    {
      "step": 1,
      "action": "connect",
      "http": { "method": "GET", "path": "/v1/health" },
      "expect": { "status": 200, "body.status": "ok" }
    },
    {
      "step": 2,
      "action": "create_spaces",
      "requests": [
        {
          "method": "POST",
          "path": "/v1/spaces",
          "body": {
            "slug": "ui-sandbox",
            "name": "UI Sandbox",
            "install_policy": "authorized_agents",
            "preview_policy": "same_origin_only"
          },
          "expect": { "space_id_prefix": "spc_" }
        },
        {
          "method": "POST",
          "path": "/v1/spaces",
          "body": {
            "slug": "ui-production",
            "name": "UI Production",
            "install_policy": "human_only",
            "preview_policy": "same_origin_only"
          },
          "expect": { "space_id_prefix": "spc_" }
        }
      ]
    },
    {
      "step": 3,
      "action": "install_review_sandbox",
      "space": "spc_ui_sandbox",
      "http": {
        "method": "POST",
        "path": "/v1/spaces/spc_ui_sandbox/capabilities/install",
        "body": {
          "package_id": "review-loop",
          "version": "2.0.0",
          "config": {
            "production_gate_enabled": true,
            "required_approver_role": "product_lead"
          },
          "target_state": "live"
        }
      },
      "expect": { "evolution_state": "live", "contract_ref_id": "cref_review_loop" }
    },
    {
      "step": 4,
      "action": "validate_and_test",
      "space": "spc_ui_sandbox",
      "sequence": [
        { "method": "POST", "path": "/v1/spaces/spc_ui_sandbox/evolution/validate", "expect": { "lens_a_pass": true } },
        { "method": "POST", "path": "/v1/spaces/spc_ui_sandbox/evolution/test", "expect": { "passed": true } }
      ]
    },
    {
      "step": 5,
      "action": "mint_worker_grant",
      "space": "spc_ui_sandbox",
      "http": {
        "method": "POST",
        "path": "/v1/spaces/spc_ui_sandbox/grants",
        "body": {
          "label": "Dev Cursor — ui-sandbox worker",
          "harness": "cursor-local",
          "template": "worker",
          "capability_acl": ["review-loop"],
          "expires_in_days": 90
        }
      },
      "expect": { "token_prefix": "tok_", "scopes_include": ["state:transition", "event:emit"] }
    },
    {
      "step": 6,
      "action": "invite_members_optional",
      "space": "spc_ui_sandbox",
      "requests": [
        {
          "method": "POST",
          "path": "/v1/spaces/spc_ui_sandbox/members",
          "body": { "email": "priya@loopcraft.com", "role": "editor" }
        },
        {
          "method": "POST",
          "path": "/v1/spaces/spc_ui_sandbox/members",
          "body": { "email": "maya@loopcraft.com", "role": "viewer" }
        }
      ]
    },
    {
      "step": 7,
      "action": "verify_space_readable",
      "http": { "method": "GET", "path": "/v1/spaces/spc_ui_sandbox" },
      "expect": { "install_policy": "authorized_agents" }
    }
  ]
}
