{
  "description": "Config CS-full (HISTORICAL — retired mcp_wake wire) — backend work.ready wakes frontend agent (c01-J02)",
  "status": "retired",
  "note": "Removal record only (Task 15 Lane C). The POST /v1/mcp/wake wire is 404 and registration of this mcp_wake trigger is rejected (422 TRIGGER_ACTION_RETIRED). The active clean protocol reacts to work.ready with an on: event: handler in .mrmr/space/handlers.yaml + murrmure_emit_event. Do not register the trigger below as active behavior.",
  "journey": "company-01/journey-02",
  "spaces": {
    "backend": "spc_backend_api",
    "frontend": "spc_ui_sandbox"
  },
  "steps": [
    {
      "action": "register_trigger",
      "historical": true,
      "expect_now": "422 TRIGGER_ACTION_RETIRED (mcp_wake retired)",
      "space": "spc_ui_sandbox",
      "http": {
        "method": "POST",
        "path": "/v1/spaces/spc_ui_sandbox/triggers",
        "body": {
          "name": "backend-ready-wake-frontend",
          "filter": {
            "event_types": ["work.ready"],
            "source_space_id": "spc_backend_api",
            "payload_match": { "type": "api_change" }
          },
          "action": {
            "type": "mcp_wake",
            "target_space_id": "spc_ui_sandbox",
            "wake_label": "handle_work_ready",
            "payload_map": {
              "type": "$.payload.type",
              "summary": "$.payload.summary",
              "openapi_diff_ref": "$.payload.openapi_diff_ref"
            }
          },
          "dedup": {
            "key_jsonpaths": ["$.payload.openapi_diff_ref"],
            "window_seconds": 86400
          }
        }
      },
      "expect": { "trigger_id_prefix": "trg_", "enabled": true }
    },
    {
      "action": "emit_work_ready",
      "space": "spc_backend_api",
      "http": {
        "method": "POST",
        "path": "/v1/spaces/spc_backend_api/events",
        "body": {
          "type": "work.ready",
          "payload": {
            "type": "api_change",
            "summary": "New /recommendations endpoint",
            "openapi_diff_ref": "blob:openapi/rec-v1.diff"
          }
        }
      },
      "expect": { "seq_min": 1 }
    },
    {
      "action": "delivery_log",
      "space": "spc_ui_sandbox",
      "http": {
        "method": "GET",
        "path": "/v1/spaces/spc_ui_sandbox/triggers/deliveries?limit=10"
      },
      "expect": { "deliveries_min": 1, "outcome": "success" }
    },
    {
      "action": "duplicate_emit_deduped",
      "note": "Same openapi_diff_ref — second delivery dropped",
      "space": "spc_backend_api",
      "http": {
        "method": "POST",
        "path": "/v1/spaces/spc_backend_api/events",
        "body": {
          "type": "work.ready",
          "payload": {
            "type": "api_change",
            "openapi_diff_ref": "blob:openapi/rec-v1.diff"
          }
        }
      }
    },
    {
      "action": "verify_dedup",
      "space": "spc_ui_sandbox",
      "http": {
        "method": "GET",
        "path": "/v1/spaces/spc_ui_sandbox/triggers/deliveries?limit=10"
      },
      "expect": { "last_delivery_dedup_reason": "duplicate_business_key" }
    }
  ]
}
