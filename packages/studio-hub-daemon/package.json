{
  "name": "@studio/hub-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "studio-hub": "./bin/studio-hub"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/main.ts",
    "start": "node --import tsx src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@runtime/kernel": "workspace:*",
    "@runtime/persistence": "workspace:*",
    "@studio/capability-sdk": "workspace:*",
    "@studio/contracts": "workspace:*",
    "@studio/hub-core": "workspace:*",
    "@studio/hub-persistence": "workspace:*",
    "@studio/triggers-templates": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.7.10",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.19.3"
  }
}
