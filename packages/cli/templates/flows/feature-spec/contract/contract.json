{
  "schemaVersion": "2.0",
  "id": "feature-spec",
  "version": "1.1.0",
  "initial_state": "gathering_context",
  "terminal_states": ["archived"],
  "metadata_schema": {
    "type": "object",
    "properties": {
      "title": { "type": "string" },
      "summary": { "type": "string", "maxLength": 512 },
      "version": { "type": "integer", "minimum": 1 },
      "sections": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "required": ["title", "body", "order"],
          "properties": {
            "title": { "type": "string" },
            "body": { "type": "string" },
            "order": { "type": "integer" }
          }
        }
      },
      "context_refs": {
        "type": "array",
        "maxItems": 32,
        "items": {
          "type": "object",
          "required": ["kind", "ref"],
          "properties": {
            "kind": { "enum": ["url", "blob"] },
            "ref": { "type": "string" },
            "label": { "type": "string" }
          }
        }
      },
      "target_repo": { "type": "string" },
      "published_at": { "type": "string", "format": "date-time" }
    }
  },
  "states": [
    { "id": "gathering_context", "kind": "active" },
    { "id": "draft", "kind": "active" },
    { "id": "in_review", "kind": "active" },
    { "id": "published", "kind": "active", "note": "Immutable content until admin revise_spec; not terminal" },
    { "id": "archived", "kind": "terminal" }
  ],
  "transitions": [
    { "id": "t_open", "from": null, "to": "gathering_context", "event": "open_spec", "actors": ["agent:*", "human:*"] },
    { "id": "t_context", "from": "gathering_context", "to": "draft", "event": "context_ready", "actors": ["agent:*", "human:*"] },
    { "id": "t_submit", "from": "draft", "to": "in_review", "event": "submit_for_review", "actors": ["agent:*", "human:*"] },
    {
      "id": "t_request_changes",
      "from": "in_review",
      "to": "draft",
      "event": "request_changes",
      "actors": ["human:*"],
      "gate": { "role_from_config": "required_approver_role" }
    },
    {
      "id": "t_approve",
      "from": "in_review",
      "to": "published",
      "event": "approve_spec",
      "actors": ["human:*"],
      "gate": { "role_from_config": "required_approver_role" }
    },
    {
      "id": "t_direct",
      "from": "draft",
      "to": "published",
      "event": "publish_direct",
      "actors": ["human:*"],
      "guard": { "config_eq": { "skip_review": true } },
      "gate": { "role_from_config": "required_approver_role" }
    },
    {
      "id": "t_revise",
      "from": "published",
      "to": "draft",
      "event": "revise_spec",
      "actors": ["human:*"],
      "gate": { "role": "space:admin" },
      "side_effect": { "increment_metadata_version": true }
    },
    {
      "id": "t_archive",
      "from": "published",
      "to": "archived",
      "event": "archive_spec",
      "actors": ["human:*"],
      "gate": { "role": "space:admin" }
    }
  ],
  "events": {
    "declarations": [
      {
        "type": "spec.published",
        "emit_on": ["enter:published"],
        "payload_schema": {
          "type": "object",
          "required": ["spec_id", "spec_key", "title", "version", "summary", "published_by", "body_ref", "section_count"],
          "properties": {
            "spec_id": { "type": "string" },
            "spec_key": { "type": "string" },
            "title": { "type": "string" },
            "version": { "type": "integer", "minimum": 1 },
            "summary": { "type": "string", "maxLength": 512 },
            "body_ref": { "type": "string" },
            "section_count": { "type": "integer" },
            "published_by": { "type": "string" }
          }
        }
      },
      {
        "type": "spec.archived",
        "emit_on": ["enter:archived"],
        "payload_schema": {
          "type": "object",
          "required": ["spec_key", "version"],
          "properties": {
            "spec_key": { "type": "string" },
            "version": { "type": "integer" }
          }
        }
      }
    ]
  },
  "inbound_queries": {
    "spec_summary@1": {
      "description": "Minimal published spec summary for cross-space ask — no raw body",
      "request_schema": {
        "type": "object",
        "properties": {
          "spec_key": { "type": "string", "description": "Optional; omit for latest published in space" }
        },
        "additionalProperties": false
      },
      "response_schema": {
        "type": "object",
        "required": ["spec_key", "title", "version", "summary"],
        "properties": {
          "spec_key": { "type": "string" },
          "title": { "type": "string" },
          "version": { "type": "integer" },
          "summary": { "type": "string" },
          "section_count": { "type": "integer" },
          "published_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  }
}
