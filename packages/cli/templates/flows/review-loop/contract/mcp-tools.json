{
  "tools": {
    "create_review_session": {
      "description": "Create a review session for a preview target and return its key.",
      "http": { "method": "POST", "path": "/sessions" },
      "input_schema": {
        "type": "object",
        "properties": {
          "view": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "get_session": {
      "description": "Read a review session by key (latest when omitted).",
      "http": { "method": "GET", "path": "/sessions/:session_key" },
      "input_schema": {
        "type": "object",
        "properties": { "session_key": { "type": "string" } }
      }
    },
    "wait_for_review": {
      "description": "Block until the current review round completes, returning the cycle result.",
      "http": { "method": "POST", "path": "/sessions/:session_key/wait" },
      "input_schema": {
        "type": "object",
        "properties": { "session_key": { "type": "string" } }
      }
    }
  }
}
